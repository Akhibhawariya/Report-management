# -----------------------------------------------------------------------------
# Copy to backend/.env for local API + worker (same variables for worker process)
# -----------------------------------------------------------------------------
# With Docker Compose as written: Postgres host port is 5433 → localhost:5433
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/report_mgmt"
# Local Redis (no Docker): use 6379. With Docker Compose as written: host port is 6380 → redis://localhost:6380
REDIS_URL="redis://localhost:6380"
PORT=4000
CORS_ORIGIN="http://localhost:3000"
UPLOADS_DIR="./uploads"
MAX_CSV_BYTES=10485760
NODE_ENV=development

# -----------------------------------------------------------------------------
# Copy to frontend/.env.local for Next.js (browser-visible API base URL)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_URL=http://localhost:4000
